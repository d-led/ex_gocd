{
  "formatsExts": {
    "elixir": ["ex", "exs", "heex"],
    "javascript": ["js", "mjs", "cjs"],
    "typescript": ["ts", "tsx"],
    "go": ["go"]
  },
  "minLines": 7,
  "minTokens": 60,
  "threshold": 1,
  "ignore": [
    "**/node_modules/**",
    "**/deps/**",
    "**/_build/**",
    "**/cover/**",
    "**/cypress/results/**",
    "**/vendor/**",
    "**/priv/static/**",
    "**/agent/work/**",
    "test/support/conn_case.ex",
    "test/support/data_case.ex",
    "lib/ex_gocd_web/router.ex"
  ]
}
